!templates/**/*.png
!templates/*.png

# Allow images in documentation stories
!docs/storys/**/*.png
!docs/storys/**/*.jpg
!docs/storys/**/*.jpeg
!docs/storys/**/*.gif


# Test coverage outputs
.coverage
htmlcov/

# Project-specific debug and grid verification screenshots
debug_click.png
debug_grid_test.png
debug_*_dim_*.png
debug_analyze_*.png

# Development drafts and temporary scratch files (entire directory)
scratch/
