# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd

# Python virtual environment
.venv/
venv/
ENV/

# OS files
.DS_Store
Thumbs.db

# Ignore all png files by default
*.png
